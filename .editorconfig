# Reference: https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[Makefile]
indent_style = tab

[*.{yaml,yml}]
indent_size = 2
indent_style = space

[*.tf]
indent_size = 2
indent_style = space

[*.py]
indent_size = 2
indent_style = space
